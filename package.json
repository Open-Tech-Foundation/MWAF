{
  "name": "web-app-framework",
  "repository": {
    "type": "git",
    "url": "https://github.com/Open-Tech-Foundation/Web-App-Framework.git"
  },
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "website"
  ],
  "scripts": {
    "dev": "vite playground",
    "build": "bun run build:web && vite build playground",
    "preview": "bun run website:build && wrangler dev",
    "website:dev": "bun run --cwd website dev",
    "website:build": "bun run build:web && bun run --cwd website build",
    "test": "bun test",
    "deploy": "bun run website:build && wrangler deploy",
    "build:web": "bun run --cwd packages/web build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@cloudflare/vite-plugin": "^1.33.1",
    "@rollup/plugin-babel": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "latest",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wrangler": "^4.84.1",
    "zod": "^4.3.6"
  }
}
